FROM python:3.11-slim

WORKDIR /gist

# Install common dependencies for gist execution
RUN pip install --no-cache-dir \
    pandas>=2.0.0 \
    numpy>=1.24.0 \
    regex>=2023 \
    requests>=2.31

# Gist code will be mounted or passed at runtime
# Set PYTHONUNBUFFERED to see output immediately
ENV PYTHONUNBUFFERED=1

# Entry point: run the gist script
ENTRYPOINT ["python"]
